{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "sym run",
      "type": "shell",
      "command": "sym run \"${file}\"",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "clear": true, "panel": "shared" },
      "problemMatcher": {
        "pattern": { "regexp": "^(.+):(\\d+):(\\d+):\\s+(.+)$", "file": 1, "line": 2, "column": 3, "message": 4 }
      }
    },
    {
      "label": "sym run verbose",
      "type": "shell",
      "command": "sym run \"${file}\" -v"
    },
    {
      "label": "sym run python",
      "type": "shell",
      "command": "sym run \"${file}\" --python"
    },
    {
      "label": "sym build native",
      "type": "shell",
      "command": "sym build -t native \"${file}\""
    },
    {
      "label": "sym check",
      "type": "shell",
      "command": "sym check \"${file}\""
    }
  ]
}
