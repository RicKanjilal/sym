{
  "comments": { "lineComment": "#" },
  "brackets": [ ["(", ")"], ["[", "]"], ["{", "}"] ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["(", ")"], ["[", "]"], ["{", "}"], ["\"", "\""], ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(fn|if|elif|else|for|while|struct|trait|impl|match|try|catch|benchmark|optimize|ƒ|f\\s+\\w)\\b.*$",
    "decreaseIndentPattern": "^\\s*(elif|else|catch|!\\s).*$"
  },
  "folding": { "offSide": true }
}
