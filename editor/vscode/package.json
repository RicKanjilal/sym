{
  "name": "symbolcore-lang",
  "displayName": "SymbolCore Language",
  "description": "Syntax highlighting, snippets, and run support for SymbolCore (.sym)",
  "version": "0.2.0",
  "publisher": "symbolcore",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages", "Snippets"],
  "contributes": {
    "languages": [{
      "id": "symbolcore",
      "aliases": ["SymbolCore", "sym"],
      "extensions": [".sym"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "symbolcore",
      "scopeName": "source.sym",
      "path": "./syntaxes/symbolcore.tmLanguage.json"
    }],
    "snippets": [{
      "language": "symbolcore",
      "path": "./snippets/symbolcore.json"
    }]
  }
}
